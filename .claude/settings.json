{
	"env": {
		"CLAUDE_CODE_MAX_OUTPUT_TOKENS": "128000"
	},
	"permissions": {
		"deny": [
			"Read(.env)",
			"Read(.env.*)",
			"Read(**/.env)",
			"Read(**/.env.*)",
			"Bash(cat .env*)",
			"Bash(cat **/.env*)",
			"Bash(grep * .env*)"
		]
	},
	"model": "claude-sonnet-4-6",
	"attribution": {
		"commit": "",
		"pr": ""
	},
	"includeCoAuthoredBy": false,
	"hooks": {
		"UserPromptSubmit": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/UserPromptSubmit.sh"
					}
				]
			}
		]
	}
}
