{
	"name": "@filen/web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build && vite build -c vite.sw.config.ts",
		"preview": "vite preview",
		"typecheck": "tsc -b --noEmit",
		"lint": "eslint . && prettier --check \"**/*.{ts,tsx}\"",
		"format": "prettier --write \"**/*.{ts,tsx}\"",
		"test": "vitest run",
		"test:e2e": "playwright test",
		"gen:error-kinds": "node --experimental-strip-types scripts/gen-error-kinds.ts",
		"check:compiler": "node --experimental-strip-types scripts/check-compiler.ts",
		"translate-i18n": "tsx scripts/translate-i18n.ts"
	},
