{
	"name": "@filen/mobile",
	"main": "./src/entry",
	"version": "0.0.0",
	"private": false,
	"scripts": {
		"postinstall": "sh scripts/postinstall.sh",
		"start": "expo start --clear",
		"android": "expo run:android",
		"android:device": "expo run:android --device",
		"android:release": "expo run:android --variant release",
		"android:device:release": "expo run:android --variant release --device",
		"android:eas:dev": "eas build --platform android --profile development",
		"android:eas:release": "eas build --platform android --profile production",
		"ios": "expo run:ios",
		"ios:release": "expo run:ios --configuration Release",
		"ios:eas:dev": "eas build --platform ios --profile development",
		"ios:eas:release": "eas build --platform ios --profile production",
		"ios:device": "expo run:ios --device",
		"ios:device:release": "expo run:ios --device --configuration Release",
		"lint": "eslint --report-unused-disable-directives --max-warnings 0 --no-warn-ignored",
		"prebuild": "expo prebuild",
		"prebuild:clean": "npm run clean && expo prebuild --clean",
		"prebuild:ci:android": "npm run superclean && expo prebuild --clean --platform android",
		"prebuild:ci:ios": "npm run superclean && expo prebuild --clean --platform ios",
		"typecheck": "node typecheck.mjs",
		"ncu": "npx expo install --fix && ncu --interactive --format group && npx expo install --fix",
		"expo:install:fix": "npx expo install --fix",
		"clean": "tsx ./clean.ts",
		"superclean": "tsx ./superclean.ts",
		"test": "vitest run",
		"verify": "npm run lint && npm run typecheck && npm run test"
	},
	"expo": {
		"install": {
			"exclude": [
				"@shopify/flash-list"
			]
		}
	},
	"op-sqlite": {
		"sqlcipher": false,
		"crsqlite": false,
		"performanceMode": true,
		"iosSqlite": true,
		"sqliteFlags": "-DSQLITE_DQS=0 -DSQLITE_TEMP_STORE=2",
		"fts5": false,
		"rtree": false,
		"libsql": false,
		"sqliteVec": false,
		"tokenizers": []
	},
	"dependencies": {
