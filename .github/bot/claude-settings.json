{
  "includeCoAuthoredBy": false,
  "disableWorkflows": true,
  "permissions": {
    "disableBypassPermissionsMode": "disable",
    "deny": [
      "Bash(curl)",
      "Bash(curl *)",
      "Bash(curl:*)",
      "Bash(wget)",
      "Bash(wget *)",
      "Bash(wget:*)",
      "Bash(nc)",
      "Bash(nc *)",
      "Bash(nc:*)",
      "Bash(ncat *)",
      "Bash(telnet *)",
      "Bash(git push --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git reset --hard:*)",
      "Bash(git stash drop *)",
      "Bash(git stash clear *)",
      "Bash(git clean -fdx *)",
      "Edit(.github/**)",
      "Write(.github/**)",
      "Edit(.claude/**)",
      "Write(.claude/**)",
      "Edit(packages/filen-mobile/filen-rs/**)",
      "Write(packages/filen-mobile/filen-rs/**)",
      "Edit(packages/filen-mobile/filen-ios-file-provider/**)",
      "Write(packages/filen-mobile/filen-ios-file-provider/**)",
      "Edit(packages/filen-mobile/filen-android-documents-provider/**)",
      "Write(packages/filen-mobile/filen-android-documents-provider/**)",
      "Edit(packages/filen-mobile/src/locales/*.json)",
      "Write(packages/filen-mobile/src/locales/*.json)",
      "Edit(packages/filen-mobile/src/locales/.en-snapshot.json)",
      "Write(packages/filen-mobile/src/locales/.en-snapshot.json)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": false,
    "allowUnsandboxedCommands": true,
    "filesystem": {
      "denyWrite": ["~/.ssh", "~/.aws", "~/.npmrc", ".github", ".claude"],
      "denyRead": ["~/.ssh", "~/.aws"]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "objects.githubusercontent.com",
        "codeload.github.com",
        "registry.npmjs.org"
      ]
    },
    "credentials": {
      "envVars": [
        { "name": "ANTHROPIC_AUTH_TOKEN", "mode": "deny" },
        { "name": "ANTHROPIC_BASE_URL", "mode": "deny" },
        { "name": "ANTHROPIC_DEFAULT_FABLE_MODEL", "mode": "deny" },
        { "name": "ANTHROPIC_DEFAULT_OPUS_MODEL", "mode": "deny" },
        { "name": "ANTHROPIC_DEFAULT_SONNET_MODEL", "mode": "deny" },
        { "name": "ANTHROPIC_DEFAULT_HAIKU_MODEL", "mode": "deny" },
        { "name": "ANTHROPIC_API_KEY", "mode": "deny" }
      ]
    }
  }
}
